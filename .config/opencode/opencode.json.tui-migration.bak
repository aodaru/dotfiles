{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  "provider": {
    "ollama": {
      "models": {
        "qcwind/qwen2.5-7B-instruct-Q4_K_M": {
          "name": "qcwind/qwen2.5-7B-instruct-Q4_K_M"
        },
        "kwangsuklee/gemma2-2b-it-Q4_K_M": {
          "name": "kwangsuklee/gemma2-2b-it-Q4_K_M"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "local-llama": {
          "name": "Local llama.cpp"
        }
      }
    }
  },
  "theme": "system"
}
